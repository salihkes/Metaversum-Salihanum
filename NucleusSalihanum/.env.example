SSL_CERT_PATH=ssl_cert.pem
SSL_KEY_PATH=ssl_key.pem

# ── NPC Chat (LLM) ──────────────────────────────────────────────────
NPC_CHAT_ENABLED=true
NPC_CHAT_REQUIRE_AUTH=false

# LLM provider: "local" or "openrouter"
LLM_PROVIDER=local

# Local LLM (llamacpp /v1/chat/completions)
LLM_BASE_URL=http://192.168.1.11:8082
LLM_MODEL=

# OpenRouter (keeps key stored, switch by changing LLM_PROVIDER)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3-flash-preview

# ── NPC TTS (Text-to-Speech) ────────────────────────────────────────
# TTS provider: "local" or "elevenlabs"
TTS_ENABLED=true
TTS_PROVIDER=local

# Local TTS (Qwen3-TTS server)
TTS_BASE_URL=http://127.0.0.1:8090
TTS_MODEL=

# ElevenLabs (keeps key stored, switch by changing TTS_PROVIDER)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_JANET=
ELEVENLABS_VOICE_GUARD=

# ── NPC STT (Speech-to-Text) ────────────────────────────────────────
# STT provider: "local" or "openai"
# "openai" works with any OpenAI-compatible API: OpenAI, Groq, ElevenLabs Scribe
STT_ENABLED=true
STT_PROVIDER=local

# Local STT (faster-whisper server)
STT_BASE_URL=http://127.0.0.1:8091

# Cloud STT (switch STT_PROVIDER to "openai" to use)
STT_API_KEY=
STT_API_MODEL=whisper-1
# OpenAI:     STT_API_URL=https://api.openai.com/v1/audio/transcriptions
# Groq:       STT_API_URL=https://api.groq.com/openai/v1/audio/transcriptions
# ElevenLabs: STT_API_URL=https://api.elevenlabs.io/v1/speech-to-text
STT_API_URL=https://api.openai.com/v1/audio/transcriptions

# ── NPC RAG (Embeddings + Reranking) ────────────────────────────────
NPC_RAG_ENABLED=false
EMBEDDING_BASE_URL=http://192.168.1.11:8081
EMBEDDING_MODEL=bge-m3-FP16
RERANK_MODEL=bge-reranker-v2-m3-FP16

# ── AgenticBase (optional smart NPC backend) ─────────────────────────
AGENTIC_BASE_URL=http://127.0.0.1:5006
