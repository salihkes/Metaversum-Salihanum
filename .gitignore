# Large model files (but keep essential VR models)
*.glb
*.fbx
*.obj
*.mtl
*.bin
*.gltf
models/
audio/

# Exclude essential VR models from ignore
!IanuaSalihana/src/external/models/
!IanuaSalihana/src/external/models/**
# But still ignore .import files in external models
IanuaSalihana/src/external/models/**/*.import

# Exclude character accessories from ignore
!IanuaSalihana/src/character/accessories/
!IanuaSalihana/src/character/accessories/**
# But still ignore .import files in accessories
IanuaSalihana/src/character/accessories/**/*.import

# Include essential world model
!IanuaSalihana/src/world/world.glb

# Ignore old workspace versions
**/workspaceold.*

# Large media files
*.mkv
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.webm

# Large audio files (but keep essential game sounds)
*.wav
*.mp3
*.ogg
*.flac
*.aac
*.m4a
*.mkv

# Exclude essential game sounds from ignore
!IanuaSalihana/src/sound/
!IanuaSalihana/src/sound/**
# But still ignore .import files in sound
IanuaSalihana/src/sound/**/*.import

# Exclude countryball character models from ignore
!IanuaSalihana/src/countryball/
!IanuaSalihana/src/countryball/**
# But still ignore .import files in countryball
IanuaSalihana/src/countryball/**/*.import

# Large image files (keep essential game textures)
# Note: Not ignoring *_diff.png etc. since they're used for character textures and accessories
# Uncomment below if you want to ignore large texture files:
# *_diff.png
# *_spec.png
# *_norm.png
# *_height.png
# *_ao.png

# Uncomment if you want to ignore all large images
# *.png
# *.jpg
# *.jpeg

# Brick mesh textures (ignore PNG files but keep folder structure)
IanuaSalihana/src/assets/BrickMeshes/**/*.png

# Object assets folder
IanuaSalihana/src/assets/Objects/

#Personal Project Files
IanuaSalihana/src/scenes/localprojectworkspace.tscn

# Root SSL files
ssl_cert.pem
ssl_key.pem

