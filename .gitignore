*.gltf
models/

# Exclude essential VR models from ignore
!IanuaSalihana/src/external/models/
!IanuaSalihana/src/external/models/**

# Exclude character accessories from ignore
!IanuaSalihana/src/character/accessories/
!IanuaSalihana/src/character/accessories/**

# Include essential world model
!IanuaSalihana/src/world/world.glb

# Ignore old workspace versions
**/workspaceold.*

# Large media files
*.mkv
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.webm

# Large audio files (but keep essential game sounds)
*.wav
*.mp3
*.ogg
*.flac
*.aac

# Exclude essential game sounds from ignore
!IanuaSalihana/src/sound/
!IanuaSalihana/src/sound/**

# Exclude countryball character models from ignore
!IanuaSalihana/src/countryball/
!IanuaSalihana/src/countryball/**

# Large image files (keep essential game textures)
# Note: Not ignoring *_diff.png etc. since they're used for character textures and accessories
# Uncomment below if you want to ignore large texture files:
# *_diff.png
# *_spec.png
# *_norm.png
# *_height.png
# *_ao.png

# Uncomment if you want to ignore all large images
# *.png
# *.jpg
# *.jpeg
